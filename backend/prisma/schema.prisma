// ============================================================
// EXPENSE TRACKER — COMPLETE PRISMA SCHEMA
// PostgreSQL + Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum ExpenseType {
  PERSONAL
  SHARED
}

enum PaymentMode {
  CASH
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
}

enum SplitStatus {
  PENDING
  PARTIALLY_PAID
  PAID
}

enum TransactionType {
  EXPENSE
  PAYMENT
}

enum BudgetPeriod {
  MONTHLY
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  SPLIT_CREATED
  PAYMENT_RECEIVED
  BUDGET_WARNING
  BUDGET_EXCEEDED
}

// ============================================================
// USER
// ============================================================

model User {
  id       String @id @default(cuid())
  name     String
  username String @unique
  email    String @unique
  password String
  currency String @default("INR")

  expenses     Expense[]
  budgets      Budget[]
  transactions Transaction[]

  sentFriendships     Friendship[] @relation("sent")
  receivedFriendships Friendship[] @relation("received")

  groupMemberships GroupMember[]
  messages         GroupMessage[]

  expenseSplits ExpenseSplit[]

  paidSharedExpenses SharedExpense[] @relation("paidBy")

  createdGroups Group[] @relation("groupCreator")

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FRIENDSHIP
// ============================================================

model Friendship {
  id String @id @default(cuid())

  senderId   String
  receiverId String

  sender   User @relation("sent", fields: [senderId], references: [id])
  receiver User @relation("received", fields: [receiverId], references: [id])

  status FriendshipStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

// ============================================================
// CATEGORY
// Seed: Food, Transport, Shopping, Education,
//       Entertainment, Health & Medical, Utilities, Others
// ============================================================

model Category {
  id   String @id @default(cuid())
  name String @unique

  expenses Expense[]
  budgets  Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// EXPENSE
// ============================================================

model Expense {
  id String @id @default(cuid())

  title  String
  amount Float
  notes  String?
  date   DateTime @default(now())

  type        ExpenseType
  paymentMode PaymentMode

  categoryId String
  userId     String

  category Category @relation(fields: [categoryId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  sharedExpense SharedExpense?
  transactions  Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([date])
}

// ============================================================
// SHARED EXPENSE
// ============================================================

model SharedExpense {
  id String @id @default(cuid())

  expenseId String  @unique
  groupId   String
  paidById  String
  title     String

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id])
  paidBy  User    @relation("paidBy", fields: [paidById], references: [id])

  splits ExpenseSplit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([paidById])
}

// ============================================================
// EXPENSE SPLIT
// ============================================================

model ExpenseSplit {
  id String @id @default(cuid())

  sharedExpenseId String
  userId          String

  sharedExpense SharedExpense @relation(fields: [sharedExpenseId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])

  owedAmount Float
  paidAmount Float       @default(0)
  status     SplitStatus @default(PENDING)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sharedExpenseId, userId])
  @@index([userId])
  @@index([sharedExpenseId])
}

// ============================================================
// TRANSACTION
// ============================================================

model Transaction {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id])

  splitId String?
  split   ExpenseSplit? @relation(fields: [splitId], references: [id])

  amount Float
  type   TransactionType
  mode   PaymentMode?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expenseId])
  @@index([splitId])
  @@index([createdAt])
}

// ============================================================
// GROUP
// ============================================================

model Group {
  id          String @id @default(cuid())
  name        String
  createdById String

  createdBy User @relation("groupCreator", fields: [createdById], references: [id])

  members        GroupMember[]
  messages       GroupMessage[]
  sharedExpenses SharedExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ============================================================
// GROUP MEMBER
// ============================================================

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// ============================================================
// GROUP MESSAGE
// ============================================================

model GroupMessage {
  id String @id @default(cuid())

  groupId String
  userId  String

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  message   String?
  expenseId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// BUDGET
// ============================================================

model Budget {
  id String @id @default(cuid())

  userId     String
  categoryId String

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  limitAmount Float
  spentAmount Float @default(0)

  period BudgetPeriod @default(MONTHLY)
  month  Int
  year   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@index([categoryId])
  @@index([month, year])
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id])

  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
