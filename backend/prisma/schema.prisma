// ============================================================
// EXPENSE TRACKER — COMPLETE PRISMA SCHEMA
// PostgreSQL + Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum ExpenseType {
  PERSONAL
  SHARED
}

enum PaymentMode {
  CASH
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
}

enum SplitStatus {
  PENDING
  PARTIALLY_PAID
  PAID
}

enum TransactionType {
  EXPENSE
  PAYMENT
}

enum BudgetPeriod {
  MONTHLY
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  SPLIT_CREATED
  PAYMENT_RECEIVED
  BUDGET_WARNING
  BUDGET_EXCEEDED
}

// ============================================================
// USER
// ============================================================

model User {
  id       String @id @default(cuid())
  name     String
  username String @unique
  email    String @unique
  password String
  currency String @default("INR")

  // expense ownership
  expenses     Expense[]
  budgets      Budget[]
  transactions Transaction[]

  // friendships
  sentFriendships     Friendship[] @relation("sent")
  receivedFriendships Friendship[] @relation("received")

  // group participation
  groupMemberships GroupMember[]
  messages         GroupMessage[]

  // splits
  expenseSplits ExpenseSplit[]

  // shared expenses paid by this user
  paidSharedExpenses SharedExpense[] @relation("paidBy")

  // groups created by this user
  createdGroups Group[] @relation("groupCreator")

  // notifications
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FRIENDSHIP
// ============================================================

model Friendship {
  id String @id @default(cuid())

  senderId   String
  receiverId String

  sender   User @relation("sent", fields: [senderId], references: [id])
  receiver User @relation("received", fields: [receiverId], references: [id])

  isAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@unique([senderId, receiverId])
}

// ============================================================
// CATEGORY
// Seed: Food, Transport, Shopping, Education,
//       Entertainment, Health & Medical, Utilities, Others
// ============================================================

model Category {
  id   String @id @default(cuid())
  name String @unique

  expenses Expense[]
  budgets  Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// EXPENSE
// ============================================================

model Expense {
  id String @id @default(cuid())

  title  String
  amount Float
  notes  String?
  date   DateTime @default(now())

  type        ExpenseType
  paymentMode PaymentMode

  categoryId String
  userId     String

  category Category @relation(fields: [categoryId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  sharedExpense SharedExpense?
  transactions  Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([date])
}

// ============================================================
// SHARED EXPENSE
// Auto-created when an expense is marked isShared = true.
// paidById = the user who paid the full bill upfront.
// A Group is auto-created with the expense title as name.
// ============================================================

model SharedExpense {
  id String @id @default(cuid())

  expenseId String  @unique
  groupId   String
  paidById  String
  title     String

  expense Expense @relation(fields: [expenseId], references: [id])
  group   Group   @relation(fields: [groupId], references: [id])
  paidBy  User    @relation("paidBy", fields: [paidById], references: [id])

  splits ExpenseSplit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([paidById])
}

// ============================================================
// EXPENSE SPLIT
// One row per participant (including the payer).
// Payer's row is created with status=PAID, paidAmount=owedAmount.
// Others start as PENDING.
// ============================================================

model ExpenseSplit {
  id String @id @default(cuid())

  sharedExpenseId String
  userId          String

  sharedExpense SharedExpense @relation(fields: [sharedExpenseId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  owedAmount Float
  paidAmount Float       @default(0)
  status     SplitStatus @default(PENDING)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sharedExpenseId])
  @@unique([sharedExpenseId, userId])
}

// ============================================================
// TRANSACTION
// Central ledger. Two use cases:
//   1. type=EXPENSE : expense created (expenseId set)
//   2. type=PAYMENT : split repayment (splitId set)
// Budget.spentAmount is updated from these records.
// ============================================================

model Transaction {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id])

  splitId String?
  split   ExpenseSplit? @relation(fields: [splitId], references: [id])

  amount Float
  type   TransactionType
  mode   PaymentMode?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expenseId])
  @@index([splitId])
  @@index([createdAt])
}

// ============================================================
// GROUP
// Auto-created when a shared expense is created.
// Name = shared expense title.
// All split participants are added as GroupMembers.
// ============================================================

model Group {
  id          String @id @default(cuid())
  name        String
  createdById String

  createdBy User @relation("groupCreator", fields: [createdById], references: [id])

  members        GroupMember[]
  messages       GroupMessage[]
  sharedExpenses SharedExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ============================================================
// GROUP MEMBER
// Junction table: which users belong to which group.
// ============================================================

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// ============================================================
// GROUP MESSAGE
// Real-time chat per group via Socket.io.
// expenseId is an optional loose reference to attach a message
// to a specific shared expense within the group.
// ============================================================

model GroupMessage {
  id String @id @default(cuid())

  groupId String
  userId  String

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  message   String?
  expenseId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// BUDGET
// One row per user + category + month + year.
// spentAmount is updated whenever a Transaction is recorded.
// For personal expenses: spentAmount += expense.amount (payer)
// For split payments:    spentAmount += payment.amount (settler)
// Warning at 80%, Exceeded at 100%.
// ============================================================

model Budget {
  id String @id @default(cuid())

  userId     String
  categoryId String

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  limitAmount Float
  spentAmount Float @default(0)

  period BudgetPeriod @default(MONTHLY)
  month  Int
  year   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@index([categoryId])
  @@index([month, year])
}

// ============================================================
// NOTIFICATION
// Persisted in DB. Also emitted via Socket.io in real-time.
// data JSON field carries contextual payload per type:
//   FRIEND_REQUEST    : { friendshipId, senderName }
//   FRIEND_ACCEPTED   : { friendshipId, receiverName }
//   SPLIT_CREATED     : { sharedExpenseId, expenseTitle, owedAmount, paidByName }
//   PAYMENT_RECEIVED  : { splitId, amount, payerName, expenseTitle }
//   BUDGET_WARNING    : { budgetId, categoryName, percentUsed, limitAmount }
//   BUDGET_EXCEEDED   : { budgetId, categoryName, limitAmount, spentAmount }
// ============================================================

model Notification {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id])

  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

